const Permission = require('../models/Permission');
const Role = require('../models/Role');

const seedRBAC = async () => {
  // Permissions
  const perms = await Permission.insertMany([
    { name: 'USER_READ', resource: 'user', action: 'read', description: 'View user profile' },
    { name: 'USER_UPDATE', resource: 'user', action: 'update', description: 'Update own profile' },
    { name: 'TEAM_CREATE', resource: 'team', action: 'create', description: 'Create team' },
    { name: 'TEAM_READ', resource: 'team', action: 'read' },
    { name: 'TEAM_UPDATE', resource: 'team', action: 'update' },
    { name: 'TEAM_DELETE', resource: 'team', action: 'delete' },
    { name: 'TASK_CREATE', resource: 'task', action: 'create' },
    { name: 'TASK_READ', resource: 'task', action: 'read' },
    { name: 'TASK_UPDATE', resource: 'task', action: 'update' },
    { name: 'TASK_DELETE', resource: 'task', action: 'delete' },
    { name: 'TEAM_MEMBER_MANAGE', resource: 'teamMember', action: 'manage' }
  ]);

  // Roles with permissions
  const adminPerms = perms.map(p => p._id);
  const leaderPerms = perms.slice(2, 11);  // Exclude user perms
  const memberPerms = [perms[7], perms[8]]; // Only task read/update

  await Role.insertMany([
    { name: 'admin', permissions: adminPerms, description: 'Full access', isSystemRole: true },
    { name: 'team_leader', permissions: leaderPerms, description: 'Team management', isSystemRole: true },
    { name: 'member', permissions: memberPerms, description: 'Basic task access', isSystemRole: true }
  ]);

  console.log('✅ RBAC seeded successfully');
  process.exit();
};

