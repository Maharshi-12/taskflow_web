const express = require('express');
const { authenticateToken } = require('../middleware/auth');
const { requirePermission, requireRoleLevel } = require('../middleware/permissions');
const Team = require('../models/Team');

const router = express.Router();

// All authenticated users can read own teams
router.get('/', authenticateToken, async (req, res) => {
  const teams = await Team.find({ 
    $or: [{ owner: req.user.id }, { members: req.user.id }] 
  });
  res.json(teams);
});

// Only team leaders/admins can create
router.post('/', 
  authenticateToken,
  requirePermission('TEAM_CREATE'),
  async (req, res) => {
    const team = await Team.create({
      ...req.body,
      owner: req.user.id
    });
    res.status(201).json(team);
  }
);

// Update own team (owner check)
router.put('/:id', 
  authenticateToken,
  requirePermission('TEAM_UPDATE'),
  async (req, res) => {
    const team = await Team.findOneAndUpdate(
      { _id: req.params.id, owner: req.user.id },
      req.body,
      { new: true }
    );
    if (!team) {
      return res.status(404).json({ message: 'Team not found or not authorized' });
    }
    res.json(team);
  }
);

module.exports = router;
