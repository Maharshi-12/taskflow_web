const Team = require('../models/Team');
const TeamMember = require('../models/TeamMember');
const User = require('../models/User');
const ActivityLog = require('../models/ActivityLog');

// @desc    Get specific team details + members (Team Leader+)
// @route   GET /api/teams/:teamId
const getTeamDetails = async (req, res) => {
  try {
    const { teamId } = req.params;
    const userId = req.user.id;

    // Verify access (owner or member)
    const team = await Team.findOne({
      _id: teamId,
      $or: [{ owner: userId }, { members: userId }]
    });

    if (!team) {
      return res.status(404).json({
        success: false,
        message: 'Team not found or access denied'
      });
    }

    // Get members with roles
    const members = await TeamMember.find({ team: teamId })
      .populate('user', 'fullName email avatar role isActive')
      .sort({ joinedAt: -1 });

    const stats = {
      totalMembers: members.length,
      activeMembers: members.filter(m => m.user.isActive).length,
      leaders: members.filter(m => m.role === 'lead').length
    };

    res.json({
      success: true,
       {
        team: {
          ...team.toObject(),
          isOwner: team.owner.toString() === userId,
          memberCount: stats.totalMembers
        },
        members,
        stats
      }
    });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
};

// @desc    Update team info (Team Leader+)
// @route   PATCH /api/teams/:teamId
const updateTeam = async (req, res) => {
  try {
    const { teamId } = req.params;
    const updates = req.body;

    // Validate updates
    const allowedUpdates = ['name', 'description', 'isPrivate', 'settings'];
    const invalidFields = Object.keys(updates).filter(field => !allowedUpdates.includes(field));
    if (invalidFields.length) {
      return res.status(400).json({
        success: false,
        message: Invalid fields: ${invalidFields.join(', ')}
      });
    }

    const team = await Team.findOneAndUpdate(
      { _id: teamId, owner: req.user.id },  // Only owner
      updates,
      { new: true, runValidators: true }
    );

    if (!team) {
      return res.status(404).json({
        success: false,
        message: 'Team not found or not authorized'
      });
    }

    // Log activity
    await ActivityLog.create({
      user: req.user.id,
      team: teamId,
      action: 'update',
      targetType: 'Team',
      targetId: team._id,
      changes: Object.entries(updates).map(([field, value]) => ({
        field, newValue: value, oldValue: null
      }))
    });

    res.json({
      success: true,
      message: 'Team updated successfully',
       team
    });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
};

// @desc    Remove member from team (Team Leader+)
// @route   DELETE /api/teams/:teamId/members/:memberId
const removeTeamMember = async (req, res) => {
  try {
    const { teamId, memberId } = req.params;
    const userId = req.user.id;

    // Verify leadership
    const teamMember = await TeamMember.findOne({
      team: teamId,
      user: userId,
      role: 'lead'
    });

    if (!teamMember && teamMember.user.toString() !== teamId) {
      return res.status(403).json({
        success: false,
        message: 'Only team leaders can remove members'
      });
    }

    // Prevent self-removal unless owner
    if (memberId === userId && !(await Team.findOne({ _id: teamId, owner: userId }))) {
      return res.status(400).json({
        success: false,
        message: 'Cannot remove yourself from team (ask owner)'
      });
    }

    // Remove membership
    const removed = await TeamMember.findOneAndDelete({
      team: teamId,
      user: memberId
    });

    if (!removed) {
      return res.status(404).json({
        success: false,
        message: 'Member not found in team'
      });
    }

    // Update user's teams array
    await User.updateOne(
      { _id: memberId },
      { $pull: { teams: teamId } }
    );

    // Log activity
    await ActivityLog.create({
      user: userId,
      team: teamId,
      action: 'remove_member',
      targetType: 'TeamMember',
      targetId: memberId
    });

    res.json({
      success: true,
      message: 'Member removed from team'
    });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
};

module.exports = { getTeamDetails, updateTeam, removeTeamMember };
const express = require('express');
const { 
  getTeamDetails, 
  updateTeam, 
  removeTeamMember 
} = require('../controllers/teamController');
const { authenticateToken, requirePermission } = require('../middleware/auth');

const router = express.Router({ mergeParams: true });

// GET /api/teams/:teamId - Team details + members
router.get('/:teamId', 
  authenticateToken, 
  requirePermission('TEAM_READ'), 
  getTeamDetails
);

// PATCH /api/teams/:teamId - Update team info
router.patch('/:teamId', 
  authenticateToken, 
  requirePermission('TEAM_UPDATE'), 
  updateTeam
);

// DELETE /api/teams/:teamId/members/:memberId
router.delete('/:teamId/members/:memberId', 
  authenticateToken, 
  requirePermission('TEAM_MEMBER_MANAGE'), 
  removeTeamMember
);

module.exports = router;
import React, { useState, useEffect } from 'react';
import { useParams } from 'react-router-dom';
import { useAuth } from '../contexts/AuthContext';
import ProtectedRoute from '../components/ProtectedRoute';
import apiClient from '../services/api';
import AddMemberModal from '../components/AddMemberModal';
import {
  PencilIcon,
  TrashIcon,
  UserPlusIcon,
  CheckIcon,
  XMarkIcon
} from '@heroicons/react/24/outline';

const TeamDetail = () => {
  const { teamId } = useParams();
  const { user } = useAuth();
  const [team, setTeam] = useState(null);
  const [loading, setLoading] = useState(true);
  const [editing, setEditing] = useState(false);
  const [formData, setFormData] = useState({});
  const [showAddMember, setShowAddMember] = useState(false);
  const [membersLoading, setMembersLoading] = useState(false);

  useEffect(() => {
    fetchTeam();
  }, [teamId]);

  const fetchTeam = async () => {
    try {
      setLoading(true);
      const response = await apiClient.get(/teams/${teamId});
      setTeam(response.data.team);
      setFormData({
        name: response.data.team.name,
        description: response.data.team.description || ''
      });
    } catch (error) {
      console.error('Failed to fetch team:', error);
    } finally {
      setLoading(false);
    }
  };

  const handleUpdateTeam = async (e) => {
    e.preventDefault();
    try {
      const response = await apiClient.patch(/teams/${teamId}, formData);
      setTeam(response.data);
      setEditing(false);
    } catch (error) {
      console.error('Update failed:', error);
    }
  };

  const handleRemoveMember = async (memberId) => {
    if (!confirm('Remove this member from the team?')) return;

    try {
      setMembersLoading(true);
      await apiClient.delete(/teams/${teamId}/members/${memberId});
      setTeam(prev => ({
        ...prev,
        members: prev.members.filter(m => m._id !== memberId)
      }));
    } catch (error) {
      console.error('Remove failed:', error);
    } finally {
      setMembersLoading(false);
    }
  };

  const canManage = team?.isOwner || team?.userRole === 'lead';

  if (loading) {
    return <div className="min-h-screen flex items-center justify-center">Loading team...</div>;
  }

  return (
    <ProtectedRoute roles={['team_leader', 'admin', 'member']}>
      <div className="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
        {/* Team Header */}
        <div className="bg-white shadow-sm border-b">
          <div className="max-w-7xl mx-auto px-6 py-8">
            <div className="flex flex-col lg:flex-row lg:items-start lg:space-x-8 space-y-6 lg:space-y-0">
              {/* Team Info */}
              <div className="flex-1">
                <div className="flex items-center space-x-4 mb-6">
                  <div className="w-20 h-20 bg-gradient-to-br from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg">
                    <span className="text-2xl font-bold text-white">{team.code}</span>
                  </div>
                  {team.isOwner && (
                    <div className="px-4 py-2 bg-emerald-100 text-emerald-800 rounded-full text-sm font-semibold">
                      Owner
                    </div>
                  )}
                </div>
                
                {editing ? (
                  <form onSubmit={handleUpdateTeam} className="space-y-4">
                    <input
                      type="text"
                      value={formData.name}
                      onChange={(e) => setFormData({ ...formData, name: e.target.value })}
                      className="w-full text-3xl font-bold text-gray-900 border-b-2 border-gray-200 pb-2 focus:border-blue-500 focus:outline-none"
                      maxLength={100}
                    />
                    <textarea
                      value={formData.description}
                      onChange={(e) => setFormData({ ...formData, description: e.target.value })}
                      rows={3}
                      className="w-full text-gray-700 border border-gray-200 rounded-lg p-4 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                      placeholder="Team description..."
                      maxLength={500}
                    />
                    <div className="flex space-x-3">
                      <button
                        type="submit"
                        className="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium flex items-center space-x-2"
                      >
                        <CheckIcon className="h-5 w-5" />
                        <span>Save</span>
                      </button>
                      <button
                        type="button"
                        onClick={() => setEditing(false)}
                        className="bg-gray-200 hover:bg-gray-300 text-gray-800 px-6 py-2 rounded-lg font-medium"
                      >
                        Cancel
                      </button>
                    </div>
                  </form>
                ) : (
                  <>
                    <h1 className="text-4xl font-bold text-gray-900 mb-3">{team.name}</h1>
                    <p className="text-xl text-gray-600 mb-6 leading-relaxed">{team.description}</p>
                    {canManage && (
                      <button
                        onClick={() => setEditing(true)}
                        className="text-blue-600 hover:text-blue-700 font-medium flex items-center space-x-2 text-sm"
                      >
                        <PencilIcon className="h-4 w-4" />
                        <span>Edit Team</span>
                      </button>
                    )}
                  </>
                )}
              </div>

              {/* Team Stats */}
              <div className="flex flex-col sm:flex-row gap-4 lg:gap-8 pt-4 lg:pt-0 border-t sm:border-t-0 sm:border-l sm:pl-8">
                <div className="text-center">
                  <div className="text-3xl font-bold text-gray-900">{team.stats?.totalMembers || 0}</div>
                  <div className="text-sm text-gray-600">Members</div>
                </div>
                <div className="text-center">
                  <div className="text-3xl font-bold text-emerald-600">{team.stats?.activeMembers || 0}</div>
                  <div className="text-sm text-gray-600">Active</div>
                </div>
                <div className="text-center">
                  <div className="text-3xl font-bold text-purple-600">{team.stats?.leaders || 0}</div>
                  <div className="text-sm text-gray-600">Leaders</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div className="max-w-7xl mx-auto px-6 py-12">
          {/* Action Buttons */}
          {canManage && (
            <div className="flex flex-wrap gap-3 mb-12">
              <button
                onClick={() => setShowAddMember(true)}
                className="bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white px-8 py-4 rounded-2xl font-semibold shadow-xl hover:shadow-2xl transition-all duration-300 flex items-center space-x-3"
              >
                <UserPlusIcon className="h-6 w-6" />
                <span>Add Member</span>
              </button>
            </div>
          )}

          {/* Members Table */}
          <div className="bg-white/70 backdrop-blur-md rounded-3xl shadow-2xl border border-white/50 overflow-hidden">
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className="bg-gradient-to-r from-gray-50 to-gray-100">
                  <tr>
                    <th className="px-8 py-5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                      Member
                    </th>
                    <th className="px-6 py-5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                      Role
                    </th>
                    <th className="px-6 py-5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                      Status
                    </th>
                    <th className="px-6 py-5 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">
                      Joined
                    </th>
                    {canManage && <th className="px-6 py-5 text-right text-xs font-semibold text-gray-700 uppercase tracking-wider w-24">
                      Actions
                    </th>}
                  </tr>
                </thead>
                <tbody className="divide-y divide-gray-200">
                  {team.members.map((member) => (
                    <tr key={member._id} className="hover:bg-gray-50 transition-colors">
                      <td className="px-8 py-6">
                        <div className="flex items-center space-x-4">
                          <div className="w-12 h-12 rounded-full bg-gradient-to-r from-blue-400 to-purple-500 flex items-center justify-center shadow-md">
                            <span className="text-white font-semibold text-sm">
                              {member.user.fullName.charAt(0)}
                            </span>
                          </div>
                          <div>
                            <div className="font-semibold text-gray-900">
                              {member.user.fullName}
                            </div>
                            <div className="text-sm text-gray-500">
                              {member.user.email}
                            </div>
                          </div>
                        </div>
                      </td>
                      <td className="px-6 py-6">
                        <span className={`px-3 py-1 rounded-full text-xs font-medium ${
                          member.role === 'lead'
                            ? 'bg-purple-100 text-purple-800'
                            : 'bg-gray-100 text-gray-800'
                        }`}>
                          {member.role === 'lead' ? 'Team Lead' : 'Member'}
                        </span>
                      </td>
                      <td className="px-6 py-6">
                        <span className={`px-3 py-1 rounded-full text-xs font-medium ${
                          member.user.isActive
                            ? 'bg-emerald-100 text-emerald-800'
                            : 'bg-red-100 text-red-800'
                        }`}>
                          {member.user.isActive ? 'Active' : 'Inactive'}
                        </span>
                      </td>
                      <td className="px-6 py-6 text-sm text-gray-500">
                        {new Date(member.joinedAt).toLocaleDateString()}
                      </td>
                      {canManage && (
                        <td className="px-6 py-6 text-right w-24">
                          <button
                            onClick={() => handleRemoveMember(member._id)}
                            className="text-red-600 hover:text-red-800 p-2 -m-2 rounded-lg hover:bg-red-50 transition-colors"
                            title="Remove from team"
                          >
                            <TrashIcon className="h-5 w-5" />
                          </button>
                        </td>
                      )}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        {showAddMember && (
          <AddMemberModal 
            teamId={teamId}
            onClose={() => setShowAddMember(false)}
            onMemberAdded={() => fetchTeam()}
          />
        )}
      </div>
    </ProtectedRoute>
  );
};

export default TeamDetail;
