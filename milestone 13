const Task = require('../models/Task');
const Team = require('../models/Team');
const User = require('../models/User');
const ActivityLog = require('../models/ActivityLog');

// @desc    Create new task (Team Leader+ only)
// @route   POST /api/tasks
// @access  Private (TASK_CREATE permission)
const createTask = async (req, res) => {
  try {
    const {
      title,
      description,
      priority = 'medium',
      dueDate,
      assigneeEmail,
      labels = [],
      teamId
    } = req.body;

    const creatorId = req.user.id;

    // 1. Input validation
    if (!title?.trim() || title.length > 200) {
      return res.status(400).json({
        success: false,
        message: 'Title is required (max 200 chars)'
      });
    }

    if (!teamId) {
      return res.status(400).json({
        success: false,
        message: 'Team ID is required'
      });
    }

    // 2. Verify team access
    const team = await Team.findOne({
      _id: teamId,
      $or: [
        { owner: creatorId },
        { members: creatorId }
      ]
    });
    if (!team) {
      return res.status(403).json({
        success: false,
        message: 'No access to this team'
      });
    }

    // 3. Validate priority
    const validPriorities = ['lowest', 'low', 'medium', 'high', 'highest'];
    if (!validPriorities.includes(priority)) {
      return res.status(400).json({
        success: false,
        message: Priority must be: ${validPriorities.join(', ')}
      });
    }

    // 4. Find assignee if specified
    let assigneeId = null;
    if (assigneeEmail) {
      const assignee = await User.findOne({ email: assigneeEmail });
      if (!assignee) {
        return res.status(404).json({
          success: false,
          message: User "${assigneeEmail}" not found
        });
      }
      assigneeId = assignee._id;
    }

    // 5. Create task
    const task = await Task.create({
      title: title.trim(),
      description: description?.trim() || '',
      priority,
      dueDate: dueDate ? new Date(dueDate) : null,
      assignee: assigneeId,
      reporter: creatorId,
      team: teamId,
      labels: Array.isArray(labels) ? labels : labels.split(',').map(l => l.trim()).filter(Boolean)
    });

    // 6. Activity log
    await ActivityLog.create({
      user: creatorId,
      team: teamId,
      task: task._id,
      action: 'create',
      targetType: 'Task',
      targetId: task._id
    });

    // 7. Populate response
    const populatedTask = await Task.findById(task._id)
      .populate('assignee reporter team', 'fullName email name code')
      .lean();

    res.status(201).json({
      success: true,
      message: 'Task created successfully',
       populatedTask
    });

  } catch (error) {
    console.error('Create task error:', error);
    res.status(500).json({
      success: false,
      message: 'Server error creating task'
    });
  }
};

// @desc    Get tasks for team (Team members+)
// @route   GET /api/tasks/team/:teamId
const getTeamTasks = async (req, res) => {
  try {
    const { teamId } = req.params;
    const { status, priority, limit = 20, page = 1 } = req.query;

    const filter = { team: teamId };
    if (status) filter.status = status;
    if (priority) filter.priority = priority;

    const tasks = await Task.find(filter)
      .populate('assignee reporter', 'fullName email avatar')
      .sort({ 
        priority: -1, 
        dueDate: 1, 
        status: 1,
        createdAt: -1 
      })
      .limit(parseInt(limit))
      .skip((parseInt(page) - 1) * parseInt(limit));

    const total = await Task.countDocuments(filter);

    res.json({
      success: true,
      count: tasks.length,
      total,
      pages: Math.ceil(total / parseInt(limit)),
       tasks
    });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
};

module.exports = { createTask, getTeamTasks };
const express = require('express');
const { createTask, getTeamTasks } = require('../controllers/taskController');
const { authenticateToken, requirePermission } = require('../middleware/auth');

const router = express.Router();

// POST /api/tasks - Create task
router.post('/', 
  authenticateToken, 
  requirePermission('TASK_CREATE'), 
  createTask
);

// GET /api/tasks/team/:teamId - Get team tasks
router.get('/team/:teamId', 
  authenticateToken, 
  requirePermission('TASK_READ'), 
  getTeamTasks
);

module.exports = router;
