require('dotenv').config();
const express = require('express');
const mongoose = require('mongoose');

const app = express();
const PORT = process.env.PORT || 3000;

// Middleware
app.use(express.json());
app.use(express.static('public'));  // Optional: serve static files

// Connection state tracking
let isConnected = false;
let connectionAttempts = 0;
const MAX_RETRIES = 5;

// MongoDB connection with comprehensive error handling
const connectDB = async () => {
  try {
    // Modern Mongoose options (no deprecated params needed in v7+)
    const conn = await mongoose.connect(process.env.MONGODB_URI, {
      serverSelectionTimeoutMS: 5000,  // Fast timeout
      socketTimeoutMS: 45000,
      maxPoolSize: 10,  // Connection pooling
      bufferCommands: false,  // Disable mongoose buffering
    });

    // Success confirmation
    console.log('✅ MongoDB Connected Successfully!');
    console.log('📊 Database:', conn.connection.name);
    console.log('🔗 Host:', conn.connection.host);
    isConnected = true;
    connectionAttempts = 0;

    // Connection events for ongoing monitoring
    mongoose.connection.on('connected', () => {
      console.log('🔄 Mongoose connected (reconnect)');
    });

    mongoose.connection.on('error', (err) => {
      console.error('❌ Mongoose connection ERROR:', err.message);
    });

    mongoose.connection.on('disconnected', () => {
      console.log('🔌 Mongoose disconnected');
      isConnected = false;
      // Auto-reconnect attempt
      if (connectionAttempts < MAX_RETRIES) {
        setTimeout(connectDB, 5000 * ++connectionAttempts);
      }
    });

    // Graceful shutdown
    process.on('SIGINT', async () => {
      await mongoose.connection.close();
      console.log('👋 MongoDB connection closed');
      process.exit(0);
    });

  } catch (error) {
    console.error('💥 MongoDB Connection FAILED:', error.message);
    console.error('🔧 Check MONGODB_URI in .env file');
    
    // Exit if critical failure
    if (connectionAttempts >= MAX_RETRIES) {
      console.error('❌ Max retries reached. Exiting...');
      process.exit(1);
    }
    
    // Retry with exponential backoff
    setTimeout(connectDB, 2000 * ++connectionAttempts);
  }
};

// Test endpoint to verify connection
app.get('/api/db-status', (req, res) => {
  res.json({
    connected: isConnected,
    dbName: mongoose.connection.name,
    host: mongoose.connection.host || 'N/A',
    models: Object.keys(mongoose.connection.models),
    uptime: process.uptime(),
    timestamp: new Date().toISOString()
  });
});

// Health check endpoint
app.get('/health', (req, res) => {
  res.json({ 
    status: 'OK', 
    dbConnected: isConnected,
    timestamp: new Date().toISOString() 
  });
});

// Sample protected route (only works if DB connected)
app.get('/api/test-query', async (req, res) => {
  if (!isConnected) {
    return res.status(503).json({ error: 'Database not connected' });
  }
  
  try {
    // Simple test collection
    const Test = mongoose.model('Test', new mongoose.Schema({
      message: String,
      timestamp: { type: Date, default: Date.now }
    }));
    
    const doc = await Test.create({ message: 'Connection verified!' });
    await doc.save();
    
    res.json({ success: true, doc });
  } catch (error) {
    res.status(500).json({ error: error.message });
  }
});

// 404 handler
app.use('*', (req, res) => {
  res.status(404).json({ error: 'Route not found' });
});

// Global error handler
app.use((error, req, res, next) => {
  console.error('Unhandled error:', error);
  res.status(500).json({ 
    error: 'Internal Server Error',
    message: error.message 
  });
});

// Start server ONLY after DB connection
const startServer = async () => {
  try {
    await connectDB();
    app.listen(PORT, () => {
      console.log(🚀 Server running on http://localhost:${PORT});
      console.log(📊 DB Status: http://localhost:${PORT}/api/db-status);
      console.log(❤️ Health: http://localhost:${PORT}/health);
    });
  } catch (error) {
    console.error('Failed to start server:', error);
    process.exit(1);
  }
};

startServer();
