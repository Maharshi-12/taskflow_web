const mongoose = require('mongoose');

const teamInviteSchema = new mongoose.Schema({
  team: {
    type: mongoose.Schema.Types.ObjectId,
    ref: 'Team',
    required: true
  },
  invitedBy: {
    type: mongoose.Schema.Types.ObjectId,
    ref: 'User',
    required: true
  },
  email: {
    type: String,
    required: true,
    lowercase: true,
    trim: true
  },
  token: {
    type: String,
    required: true,
    unique: true
  },
  role: {
    type: String,
    enum: ['lead', 'member'],
    default: 'member'
  },
  status: {
    type: String,
    enum: ['pending', 'accepted', 'declined', 'expired'],
    default: 'pending'
  },
  expiresAt: {
    type: Date,
    default: () => new Date(Date.now() + 7 * 24 * 60 * 60 * 1000) // 7 days
  }
}, {
  timestamps: true
});

// Auto-expire invites
teamInviteSchema.index({ expiresAt: 1 }, { expireAfterSeconds: 0 });
teamInviteSchema.index({ team: 1, email: 1 }, { unique: true }); // Prevent duplicate invites

module.exports = mongoose.model('TeamInvite', teamInviteSchema);
const Team = require('../models/Team');
const TeamMember = require('../models/TeamMember');
const User = require('../models/User');
const TeamInvite = require('../models/TeamInvite');
const ActivityLog = require('../models/ActivityLog');
const crypto = require('crypto');
const nodemailer = require('nodemailer'); // npm i nodemailer

// Generate unique invite token
const generateInviteToken = () => {
  return crypto.randomBytes(32).toString('hex');
};

// Send invite email
const sendInviteEmail = async (invite) => {
  // Configure your email service (Gmail, SendGrid, etc.)
  const transporter = nodemailer.createTransport({
    service: 'gmail',
    auth: {
      user: process.env.EMAIL_USER,
      pass: process.env.EMAIL_PASS
    }
  });

  const inviteUrl = ${process.env.FRONTEND_URL}/team/invite/${invite.token};
  
  await transporter.sendMail({
    from: '"Team Manager" <noreply@yourapp.com>',
    to: invite.email,
    subject: Invitation to join "${invite.team.name}" team,
    html: `
      <h2>You've been invited to join a team!</h2>
      <p><strong>Team:</strong> ${invite.team.name}</p>
      <p><strong>Role:</strong> ${invite.role}</p>
      <p><strong>Invited by:</strong> ${invite.invitedBy.fullName}</p>
      <a href="${inviteUrl}" style="background: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold;">Accept Invitation</a>
      <p style="margin-top: 20px; color: #666;">This invitation expires in 7 days.</p>
    `
  });
};

// @desc    Add/invite member to team (Team Leader only)
// @route   POST /api/teams/:teamId/members
const addTeamMember = async (req, res) => {
  try {
    const { teamId } = req.params;
    const { email, role = 'member' } = req.body;
    const leaderId = req.user.id;

    // 1. Verify leader owns/manages team
    const team = await Team.findOne({
      _id: teamId,
      $or: [{ owner: leaderId }, { 'members': leaderId }]
    });
    if (!team) {
      return res.status(404).json({
        success: false,
        message: 'Team not found or access denied'
      });
    }

    // 2. Check if user already member
    const existingMember = await TeamMember.findOne({
      user: req.user.id,
      team: teamId
    });
    if (existingMember) {
      return res.status(400).json({
        success: false,
        message: ${email} is already a team member
      });
    }

    // 3. Check if pending invite exists
    const existingInvite = await TeamInvite.findOne({
      team: teamId,
      email,
      status: 'pending'
    });
    if (existingInvite) {
      return res.status(400).json({
        success: false,
        message: Invite already sent to ${email}
      });
    }

    // 4. Check if user exists (direct add)
    const user = await User.findOne({ email });
    if (user) {
      // Direct add existing user
      await TeamMember.create({
        user: user._id,
        team: teamId,
        role
      });

      await User.findByIdAndUpdate(user._id, {
        $push: { teams: teamId }
      });

      await ActivityLog.create({
        user: leaderId,
        team: teamId,
        action: 'add_member',
        targetType: 'TeamMember',
        targetId: user._id
      });

      res.json({
        success: true,
        message: ${user.fullName} added to team,
         { user: { id: user._id, fullName: user.fullName, email } }
      });
    } else {
      // 5. Create invite for new/existing unregistered user
      const inviteToken = generateInviteToken();
      const invite = await TeamInvite.create({
        team: teamId,
        invitedBy: leaderId,
        email,
        role,
        token: inviteToken
      });

      // Populate for email
      await invite.populate('team invitedBy', 'name fullName email');

      // Send email
      await sendInviteEmail(invite);

      res.status(201).json({
        success: true,
        message: Invitation sent to ${email},
         { inviteId: invite._id, expiresAt: invite.expiresAt }
      });
    }

  } catch (error) {
    console.error('Add member error:', error);
    res.status(500).json({
      success: false,
      message: 'Failed to process request'
    });
  }
};

// @desc    Accept team invite
// @route   POST /api/team/invites/:token/accept
const acceptInvite = async (req, res) => {
  try {
    const { token } = req.params;
    const userId = req.user.id;

    const invite = await TeamInvite.findOne({
      token,
      status: 'pending',
      expiresAt: { $gt: new Date() }
    }).populate('team invitedBy');

    if (!invite) {
      return res.status(404).json({
        success: false,
        message: 'Invalid or expired invite'
      });
    }

    // Add to team
    await TeamMember.create({
      user: userId,
      team: invite.team._id,
      role: invite.role
    });

    await User.findByIdAndUpdate(userId, {
      $push: { teams: invite.team._id }
    });

    // Mark invite as accepted
    invite.status = 'accepted';
    await invite.save();

    res.json({
      success: true,
      message: Joined team "${invite.team.name}",
       { teamId: invite.team._id }
    });

  } catch (error) {
    res.status(500).json({
      success: false,
      message: error.message
    });
  }
};

module.exports = { addTeamMember, acceptInvite };
