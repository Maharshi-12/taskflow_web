const searchTasksAndTeams = async (req, res) => {
  try {
    const q = (req.query.q || '').trim();

    if (!q) {
      return res.json({
        success: true,
        data: { tasks: [], teams: [] }
      });
    }

    const [tasks, teams] = await Promise.all([
      Task.find(
        { $text: { $search: q } },
        { score: { $meta: 'textScore' }, title: 1, description: 1, status: 1, team: 1, assignee: 1 }
      )
        .sort({ score: { $meta: 'textScore' } })
        .limit(20)
        .lean(),

      Team.find(
        { $text: { $search: q } },
        { score: { $meta: 'textScore' }, name: 1, code: 1, description: 1 }
      )
        .sort({ score: { $meta: 'textScore' } })
        .limit(20)
        .lean()
    ]);

    return res.json({
      success: true,
      data: { tasks, teams }
    });
  } catch (error) {
    return res.status(500).json({
      success: false,
      message: 'Search failed'
    });
  }
};
