const express = require('express');
const { authenticateToken, requirePermission } = require('../middleware/auth');
const Task = require('../models/Task');
const Team = require('../models/Team');

const router = express.Router();

// GET /api/dashboard - Authenticated users only
router.get('/dashboard', authenticateToken, async (req, res) => {
  const teams = await Team.countDocuments({ 
    $or: [{ owner: req.user.id }, { members: req.user.id }] 
  });
  const tasks = await Task.countDocuments({ assignee: req.user.id });
  
  res.json({
    success: true,
    dashboard: {
      teams,
      tasks,
      user: req.user
    }
  });
});

// GET /api/teams - Team Leaders+
router.get('/teams', 
  authenticateToken, 
  requirePermission('TEAM_READ'), 
  async (req, res) => {
    const teams = await Team.find({
      $or: [{ owner: req.user.id }, { members: req.user.id }]
    }).populate('owner members', 'fullName email');
    res.json(teams);
  }
);

// POST /api/tasks - Any authenticated user
router.post('/tasks', 
  authenticateToken, 
  requirePermission('TASK_CREATE'), 
  async (req, res) => {
    const task = await Task.create({
      ...req.body,
      reporter: req.user.id
    });
    res.status(201).json(task);
  }
);

