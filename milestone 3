6. ActivityLog Model (models/ActivityLog.js)
javascript
const mongoose = require('mongoose');

const activityLogSchema = new mongoose.Schema({
  user: {
    type: mongoose.Schema.Types.ObjectId,
    ref: 'User',
    required: true
  },
  team: {
    type: mongoose.Schema.Types.ObjectId,
    ref: 'Team'
  },
  resource: {
    type: {
      type: String,
      enum: ['User', 'Team', 'Task', 'Comment', 'TeamMember']
    },
    id: {
      type: mongoose.Schema.Types.ObjectId,
      required: true
    }
  },
  action: {
    type: String,
    enum: ['create', 'update', 'delete', 'assign', 'comment', 'login'],
    required: true
  },
  changes: [{
    field: String,
    oldValue: mongoose.Schema.Types.Mixed,
    newValue: mongoose.Schema.Types.Mixed
  }],
  ipAddress: {
    type: String,
    trim: true
  },
  userAgent: String,
  severity: {
    type: String,
    enum: ['info', 'warning', 'error'],
    default: 'info'
  }
}, {
  timestamps: true
});

// TTL index: Delete logs after 90 days
activityLogSchema.index({ createdAt: 1 }, { expireAfterSeconds: 7776000 });
activityLogSchema.index({ team: 1, createdAt: -1 });
activityLogSchema.index({ user: 1, action: 1 });

module.exports = mongoose.model('ActivityLog', activityLogSchema);
Usage with Population (server.js)
javascript
// Import all models
const User = require('./models/User');
const Team = require('./models/Team');
// ... etc

// Example queries with population
app.get('/api/teams/:id', async (req, res) => {
  const team = await Team.findById(req.params.id)
    .populate('owner', 'fullName email avatar')
    .populate({
      path: 'tasks',
      match: { status: 'todo' },
      populate: {
        path: 'assignee reporter',
        select: 'fullName avatar'
      }
    });
  res.json(team);
});
