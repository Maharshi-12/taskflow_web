// middleware/rejectMongoOperators.js
const containsDangerousKeys = (obj) => {
  if (!obj || typeof obj !== 'object') return false;

  for (const key of Object.keys(obj)) {
    if (key.startsWith('$') || key.includes('.')) {
      return true;
    }

    if (typeof obj[key] === 'object' && containsDangerousKeys(obj[key])) {
      return true;
    }
  }

  return false;
};

const rejectMongoOperators = (req, res, next) => {
  if (containsDangerousKeys(req.body) || containsDangerousKeys(req.query) || containsDangerousKeys(req.params)) {
    return res.status(400).json({
      success: false,
      message: 'Invalid input structure'
    });
  }

  next();
};

module.exports = rejectMongoOperators;
